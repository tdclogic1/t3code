{
  "name": "ct-round-5",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run build:contracts && VITE_WS_URL=ws://localhost:3773 turbo run dev --filter=@acme/renderer --filter=t3 --parallel",
    "dev:server": "bun run build:contracts && bun run --cwd apps/server dev",
    "dev:web": "VITE_WS_URL=ws://localhost:3773 bun run --cwd apps/renderer dev",
    "start": "node apps/server/dist/index.js",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "fmt": "oxfmt",
    "smoke-test": "turbo run smoke-test",
    "build:contracts": "bun run --cwd packages/contracts build"
  },
  "devDependencies": {
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.9"
}
